# ──────────────────────────────────────────────────────────────────
# Offinity_AI Configuration
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────

# ── Provider ──────────────────────────────────────────────────────
# Options: lmstudio | ollama | openai | anthropic | openrouter
SC_PROVIDER=lmstudio

# ── LM Studio (local — free) ──────────────────────────────────────
# Best models for code (2025):
#   qwen2.5-coder-32b-instruct     ← top-ranked open-source coder
#   qwen2.5-coder-7b-instruct      ← fast, strong on 8GB VRAM
#   deepseek-coder-v2-lite         ← great reasoning + code
#   codestral-22b                  ← 86% HumanEval, fill-in-middle
SC_URL=http://localhost:1234/v1
SC_MODEL=                        # leave blank to auto-detect loaded model

# ── Ollama (local — free) ─────────────────────────────────────────
# Best models:
#   ollama pull qwen2.5-coder:7b       ← fast, strong, 256k context
#   ollama pull qwen2.5-coder:32b      ← best quality (needs 24GB VRAM)
#   ollama pull codestral:22b          ← excellent code completion
#   ollama pull deepseek-coder-v2:16b  ← reasoning + code
# SC_PROVIDER=ollama
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5-coder:7b

# ── OpenRouter (free tier available) ──────────────────────────────
# Free models (no API cost):
#   deepseek/deepseek-coder-v2-lite-instruct:free
#   qwen/qwen-2.5-coder-32b-instruct:free
#   meta-llama/llama-3.1-8b-instruct:free
# SC_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=qwen/qwen-2.5-coder-32b-instruct:free

# ── OpenAI ────────────────────────────────────────────────────────
# SC_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini     # fast + cheap
# OPENAI_MODEL=gpt-4o          # best quality

# ── Anthropic ─────────────────────────────────────────────────────
# SC_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6   # best balance
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001    # fastest + cheapest

# ── Generation parameters ─────────────────────────────────────────
SC_MAX_TOKENS=8192          # max output tokens per file
SC_TEMPERATURE=0.1          # 0.0–1.0 (lower = more deterministic = better for code)
SC_RETRIES=3                # auto-retry on empty/invalid output
SC_TIMEOUT=240              # seconds to wait for LLM response

# ── Context window ────────────────────────────────────────────────
# CRITICAL for local models: must match n_ctx/context length of your loaded model.
# Larger = more code context = better multi-file understanding.
# Recommended settings:
#   4096   — default / small models / limited VRAM
#   8192   — qwen2.5-coder:7b, codestral, deepseek-coder-v2-lite
#   32768  — qwen2.5-coder:32b, cloud APIs (OpenAI, Anthropic, OpenRouter)
#  131072  — qwen2.5-coder:7b Ollama (it supports 128k context natively)
SC_CONTEXT_WINDOW=8192

# ── Web UI ────────────────────────────────────────────────────────
SC_PORT=7432                # Web UI port (http://localhost:7432)
SC_HOST=127.0.0.1           # Use 0.0.0.0 to allow LAN access

# ── Logging ───────────────────────────────────────────────────────
# Options: DEBUG | INFO | WARNING | ERROR
SC_LOG_LEVEL=INFO
